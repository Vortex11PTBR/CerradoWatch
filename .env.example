# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env

# ── Banco de dados ─────────────────────────────────────────────────────────────
# Opção 1 — URL completa (Neon / Render / Railway) ← RECOMENDADO
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Opção 2 — variáveis individuais (desenvolvimento local com Docker)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=cerradowatch
# POSTGRES_USER=cerrado_user
# POSTGRES_PASSWORD=sua_senha_segura_aqui

# ── INPE / FIRMS (NASA) ────────────────────────────────────────────────────────
# Obtenha sua chave em: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=sua_chave_aqui

# ── Alertas por e-mail ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_app_password_aqui
ALERT_EMAIL_TO=destinatario@email.com

# ── Configurações ──────────────────────────────────────────────────────────────
FIRMS_ALERT_THRESHOLD=500
APP_ENV=development
LOG_LEVEL=INFO
